# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=tu_usuario
DB_PASSWORD=tu_contraseña
DB_DATABASE=nombre_db

# JWT
JWT_SECRET=tu_secreto_jwt
JWT_EXPIRATION=24h

# Entorno (dev, qa, prod)
ENV=dev

# Google Cloud Logging
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
GOOGLE_CLOUD_PROJECT_ID=tu_proyecto_gcp

# Mercado Libre OAuth
ML_CLIENT_ID=tu_client_id
ML_CLIENT_SECRET=tu_client_secret
ML_REDIRECT_URI=https://tu-dominio.com/mercado-libre

# SII - BaseAPI (Para sincronización de compras)
BASE_API_KEY=sk_your_api_key_here
SII_RUT=12345678-9
SII_PASSWORD=tu_password_sii
