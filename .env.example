# Base de datos
DB_HOST=TU_HOST
DB_PORT=TU_PUERTO
DB_USER=TU_USUARIO
DB_PASS=TU_PASSWORD
DB_NAME=TU_BASE_DE_DATOS

# JWT
JWT_SECRET=TU_SECRETO_JWT

# Entorno (dev, prod)
ENV=TU_ENTORNO

# Mercado Libre
ML_CLIENT_ID=TU_CLIENT_ID
ML_CLIENT_SECRET=TU_CLIENT_SECRET

# SII - Scraping RCV
SII_RUT=TU_RUT
SII_PASSWORD=TU_PASSWORD_SII

# WooCommerce
WOO_BASE_URL=TU_URL_TIENDA
WOO_CONSUMER_KEY=TU_CONSUMER_KEY
WOO_CONSUMER_SECRET=TU_CONSUMER_SECRET

# (Opcional) Puerto de la app (default: 3000)
PORT=TU_PUERTO

# (Opcional) Ruta a Chrome en Docker/Raspberry Pi
# CHROME_BIN=/usr/bin/google-chrome-stable
